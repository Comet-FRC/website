---
import { getCollection } from "astro:content";

const allRobots = await getCollection("robots", ({ data }) =>
  import.meta.env.PROD ? !data.draft : true
);

const competitionRobots = allRobots
  .filter((robot) => robot.data.competition !== false)
  .sort((a, b) => a.data.order - b.data.order);

const offseasonRobots = allRobots
  .filter((robot) => robot.data.competition === false)
  .sort((a, b) => a.data.order - b.data.order);
---

<section id="robots" class="py-16">
  <div class="container mx-auto px-4">

    <!-- Competition Robots Section -->
    <h2 class="text-3xl font-bold text-center mb-4">Competition Robots</h2>
    <p class="text-center text-gray-600 mb-12">
      Robots built for official FRC seasons.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 auto-rows-fr mb-16">
      {competitionRobots.map(robot => (
        <a
          href={`/robots/${robot.slug}`}
          class="block bg-white rounded-lg shadow overflow-hidden group aspect-square"
        >
          <div class="relative w-full h-full overflow-hidden">
            <img loading="lazy"
              src={robot.data.pic}
              alt={robot.data.name}
              class="w-full h-full object-cover transition-all duration-300 group-hover:brightness-[0.35]"
            />

            <div class="absolute inset-0 flex flex-col items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              <h3 class="text-white text-xl font-bold text-center px-4">{robot.data.name}</h3>
              {robot.data.season && (
                <p class="text-gray-200 text-sm mt-1">
                  {robot.data.season.replace(/^\d{4}\s*/, '')}
                </p>
              )}
            </div>
          </div>
        </a>
      ))}
    </div>

    <!-- Offseason Robots Section (only shown if there are any) -->
    {offseasonRobots.length > 0 && (
      <>
        <h2 class="text-3xl font-bold text-center mb-4">Offseason Robots</h2>
        <p class="text-center text-gray-600 mb-12">
          Experimental bots and practice platforms.
        </p>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 auto-rows-fr">
          {offseasonRobots.map(robot => (
            <a
              href={`/robots/${robot.slug}`}
              class="block bg-white rounded-lg shadow overflow-hidden group aspect-square"
            >
              <div class="relative w-full h-full overflow-hidden">
                <img loading="lazy"
                  src={robot.data.pic}
                  alt={robot.data.name}
                  class="w-full h-full object-cover transition-all duration-300 group-hover:brightness-[0.35]"
                />

                <div class="absolute inset-0 flex flex-col items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                  <h3 class="text-white text-xl font-bold text-center px-4">{robot.data.name}</h3>
                  {robot.data.season && (
                    <p class="text-gray-200 text-sm mt-1">{robot.data.season}</p>
                  )}
                </div>
              </div>
            </a>
          ))}
        </div>
      </>
    )}

  </div>
</section>