---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/Sections/PageHeader.astro";
import Button from "../components/UI/Button.astro";
import RobotList from "../components/Sections/RobotList.astro";
import { getCollection } from "astro:content";

// Find the most recent official season robot (competition robots sorted by order)
const allRobots = await getCollection("robots", ({ data }) =>
  import.meta.env.PROD ? !data.draft : true
);

// Sort by order to find the latest season (order 1 = newest), only competition robots
const latestRobot = allRobots
  .filter((robot) => robot.data.competition !== false)
  .sort((a, b) => a.data.order - b.data.order)[0];
---

<BaseLayout
  title="Robots - Comet Robotics"
  description="Complete list of COMET robots."
>
  <PageHeader 
    title="Robots" 
    subtitle="Thriving with quality robots"
    backgroundImage="/uploads/header/robots-header.avif"
  />

  {
    latestRobot && (
      <section class="bg-gradient-to-br from-primary-50 to-primary-100 py-16">
        <div class="container mx-auto px-4">
          <div class="max-w-5xl mx-auto">
            <p class="text-primary-600 font-semibold text-center mb-2 uppercase tracking-wider">Current Season</p>
            <h2 class="text-3xl font-bold text-center mb-8">Featured Robot</h2>

            <div class="bg-white rounded-2xl shadow-xl overflow-hidden">
              <div class="grid grid-cols-1 md:grid-cols-2">
                {/* Robot Image */}
                <div class="bg-gray-100 p-8 flex items-center justify-center">
                  <img
                    src={latestRobot.data.pic}
                    alt={latestRobot.data.name}
                    class="max-w-full max-h-[300px] object-contain"
                  />
                </div>

                {/* Robot Info */}
                <div class="p-8 flex flex-col justify-center">
                  <h3 class="text-2xl font-bold mb-2">{latestRobot.data.name}</h3>
                  {latestRobot.data.season && (
                    <p class="text-primary-600 mb-4">{latestRobot.data.season} Season</p>
                  )}
                  {latestRobot.data.description && (
                    <p class="text-gray-700 mb-6">{latestRobot.data.description}</p>
                  )}

                  <div class="flex flex-wrap gap-3">
                    <Button href={`/robots/${latestRobot.slug}`} variant="primary">
                      View Full Page &rarr;
                    </Button>
                    {latestRobot.data.cad && (
                      <Button
                        href={latestRobot.data.cad}
                        target="_blank"
                        variant="outline"
                      >
                        Explore CAD
                      </Button>
                    )}
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
    )
  }

  <div class="bg-white">
    <RobotList/>
  </div>
</BaseLayout>
